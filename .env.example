# --- Frontend (Vite) ---
# Solo variables con prefijo VITE_ se exponen al cliente.
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key
# Dejar vacío si la API va en el mismo dominio (Vercel: /api → serverless).
# Opcional: hosts extra para Vite en red local (coma-separados)
# VITE_ALLOWED_HOSTS=mi-pc.local,192.168.1.10
# VITE_DEV_PORT=5173

# --- Servidor admin (server/) ---
ADMIN_PORT=3080
# En producción incluye tu dominio Vercel, separado por comas.
CORS_ORIGIN=http://localhost:5173,https://haistore.vercel.app

# Credenciales de servidor para Supabase (NUNCA exponer al cliente).
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Para aplicar migraciones SQL desde scripts (Account → Access Tokens):
# SUPABASE_ACCESS_TOKEN=sbp_...
# O URI de Postgres (Settings → Database → Connection string):
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@...

# Integración HaiSupport (opcional; vacío = modo demo).
# POST {HAISUPPORT_API_URL}/tickets — tickets de contacto/ruleta
# POST {HAISUPPORT_API_URL}/sync/{entity} — cambios HaiStore → HaiSupport (si SYNC enabled)
HAISUPPORT_API_URL=
HAISUPPORT_API_KEY=
# Sincronizar cambios de inventario/clientes/cotizaciones/servicios/alquileres hacia HaiSupport API
HAISUPPORT_SYNC_ENABLED=true
# Secreto compartido para webhook HaiSupport → HaiStore (header X-HaiSupport-Secret)
HAISUPPORT_WEBHOOK_SECRET=

# Fuente de datos compartida HaiStore ↔ HaiSupport (Supabase). Usar "file" solo en offline.
# HAISTORE_DATA_SOURCE=file
HAISTORE_CATALOG_SOURCE=supabase

# Migraciones: 007 (proformas/planes), 008 (servicios/alquileres/clientes ampliados)
# Ver docs/haisupport-sync-contract.md

# Cuentas demo locales (sin Supabase): server/lib/auth-store.js
# admin@haitech.pe / admin123 | soporte@haitech.pe / demo123
# mayorista@haitech.pe / demo123
# corporativo@haitech.pe / demo123 | tecnico@haitech.pe / demo123
# distribuidor@haitech.pe / demo123 | vip@haitech.pe / demo123
#
# Migración Supabase: ejecutar supabase/migrations/001_profiles_auth.sql
#
# --- Vercel (Panel → Settings → Environment Variables) ---
# Mismas claves que arriba para Production:
#   VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY
#   SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY
#   CORS_ORIGIN=https://haistore.vercel.app
# Opcional: HAISUPPORT_API_URL, HAISUPPORT_API_KEY
# HAISTORE_CATALOG_SOURCE=supabase|file (por defecto: supabase en Vercel, archivo en local)
#
# Sincronizar .env → Vercel: node scripts/push-vercel-env.mjs
# Migración catálogo: supabase/migrations/005_products_catalog_fields.sql
